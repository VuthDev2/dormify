# ──────────────────────────────────────────────────────────────
# Dormify — environment variable template
# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file with real secrets.
# ──────────────────────────────────────────────────────────────

# Supabase project URL — find in: Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase anon/public key — safe to expose to the browser (RLS enforced)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Supabase service-role key — SERVER ONLY, never expose to the browser.
# Used for admin operations that must bypass RLS (e.g., creating notifications).
# Find in: Supabase dashboard → Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
